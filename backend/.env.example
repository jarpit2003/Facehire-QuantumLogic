DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/fairhire
GEMINI_API_KEY=<your-gemini-api-key>
ENVIRONMENT=development
MAX_UPLOAD_SIZE_MB=10.0
ALLOWED_ORIGINS=["http://localhost:3000"]

# JWT Auth
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# SMTP Email (optional — set SMTP_ENABLED=true to activate)
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=<your-gmail>@gmail.com
SMTP_PASSWORD=<your-gmail-app-password>
SMTP_FROM_EMAIL=<your-gmail>@gmail.com

# X / Twitter API v2 (optional)
X_ENABLED=false
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# Google Forms (optional — requires credentials.json)
GOOGLE_FORMS_ENABLED=false
GOOGLE_CREDENTIALS_PATH=credentials.json
